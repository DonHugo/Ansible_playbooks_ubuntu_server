# ============================================================
# Paperless Stack — environment variables template
# Copy this file to /home/hugo/paperless/.env on the server
# and fill in all values marked with <CHANGE_ME>
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
PAPERLESS_DB_NAME=paperless
PAPERLESS_DB_USER=paperless
PAPERLESS_DB_PASS=<CHANGE_ME>

# ------------------------------------------------------------
# Paperless-NGX core
# ------------------------------------------------------------
# Generate with: openssl rand -base64 48
PAPERLESS_SECRET_KEY=<CHANGE_ME>

# Public URL (used for links in notifications / email)
PAPERLESS_URL=http://192.168.0.111:8010

# Hosts Django will accept requests from — include the internal Docker alias
# so paperless-ai can reach paperless-ngx container-to-container
PAPERLESS_ALLOWED_HOSTS=paperless-ngx,192.168.0.111,localhost,127.0.0.1

# Admin account (created on first start)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=<CHANGE_ME>
PAPERLESS_ADMIN_MAIL=admin@localhost

# OCR languages — install additional tesseract packages if needed
# Common codes: eng swe deu fra spa nld
PAPERLESS_OCR_LANGUAGE=eng+swe

# Timezone
TZ=Europe/Stockholm

# ------------------------------------------------------------
# Paperless-AI
# ------------------------------------------------------------
PAPERLESS_AI_INITIAL_SETUP=yes

# The Paperless-NGX user that paperless-ai will act as.
# Use a regular (non-admin) user so AI-created tags/correspondents/document types
# still need to be set to global (owner=None) via Django shell, OR ensure this
# user's objects are created globally by default.
# IMPORTANT: Must match the user whose API token is set in PAPERLESS_API_TOKEN.
PAPERLESS_USERNAME=hugo

# Token obtained from Paperless-NGX for the PAPERLESS_USERNAME user above.
# Generate via Django shell:
#   docker exec paperless_ngx python3 manage.py shell -c "
#   from rest_framework.authtoken.models import Token
#   from django.contrib.auth.models import User
#   u = User.objects.get(username='hugo')
#   token, _ = Token.objects.get_or_create(user=u)
#   print(token.key)"
PAPERLESS_API_TOKEN=<GET_FROM_PAPERLESS_ADMIN>

# AI provider: openai | ollama | custom
AI_PROVIDER=openai

# --- OpenAI (cloud, primary) ---
OPENAI_API_KEY=<CHANGE_ME>
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local, optional — leave blank if using OpenAI) ---
OLLAMA_API_URL=http://192.168.0.111:11434
OLLAMA_MODEL=llama3.2

# --- Custom / DeepSeek / OpenRouter / LiteLLM ---
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# --- Scan & processing settings ---
# Cron: every 30 minutes by default
SCAN_INTERVAL=*/30 * * * *
PROCESS_PREDEFINED_DOCUMENTS=yes

# Tag that triggers AI processing in paperless-ngx
PAPERLESS_AI_TAGS=pre-process

# Tag applied after AI has processed a document
ADD_AI_PROCESSED_TAG=yes
AI_PROCESSED_TAG_NAME=ai-processed

# Use existing document data (title/tags) as context: yes | no
USE_EXISTING_DATA=no

# RAG (Retrieval-Augmented Generation) chat
RAG_SERVICE_ENABLED=true
